{
  "manifest_version": 3,
  "name": "Screen Time Tracker",
  "version": "1.0",
  "description": "Tracks browsing time and sends to backend",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": ["http://localhost:5002/*"],
  "background": {
    "service_worker": "background.js"
  }
}