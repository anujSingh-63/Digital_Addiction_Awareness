<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Track Screen Time - Digital Addiction Awareness</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Track Screen Time</h1>
      <p class="text-slate-600">Hello, <%= userName %>. Add entries manually or use live session tracking.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-700 border border-red-200">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-700 border border-green-200">
        <%= success %>
      </div>
    <% } %>

    <div class="grid md:grid-cols-3 gap-4 mb-6">
      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Today's Total</p>
        <p class="text-2xl font-bold text-indigo-700"><%= todayTotal || 0 %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Sessions Today</p>
        <p class="text-2xl font-bold text-blue-700"><%= sessionCount || 0 %></p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Status</p>
        <p id="sessionStatus" class="text-2xl font-bold text-green-600">Idle</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 mb-8">
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-6">
          <%= editEntry ? "Edit Entry" : "Add Screen Time Manually" %>
        </h2>

        <form action="<%= editEntry ? '/track-screen-time/update/' + editEntry._id : '/track-screen-time' %>" method="POST" class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Category</label>
            <select name="category" class="w-full border rounded-lg px-4 py-3" required>
              <option value="">Select category</option>
              <option value="Social Media" <%= editEntry && editEntry.category === 'Social Media' ? 'selected' : '' %>>Social Media</option>
              <option value="Entertainment" <%= editEntry && editEntry.category === 'Entertainment' ? 'selected' : '' %>>Entertainment</option>
              <option value="Study" <%= editEntry && editEntry.category === 'Study' ? 'selected' : '' %>>Study</option>
              <option value="Gaming" <%= editEntry && editEntry.category === 'Gaming' ? 'selected' : '' %>>Gaming</option>
              <option value="Other" <%= editEntry && editEntry.category === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>

          <div>
            <label class="block mb-2 font-medium">Hours</label>
            <input
              type="number"
              name="hours"
              step="0.1"
              min="0"
              max="24"
              value="<%= editEntry ? editEntry.hours : '' %>"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Notes</label>
            <input
              type="text"
              name="notes"
              placeholder="Optional notes"
              value="<%= editEntry ? editEntry.notes : '' %>"
              class="w-full border rounded-lg px-4 py-3"
            >
          </div>

          <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
              <%= editEntry ? "Update Entry" : "Add Screen Time" %>
            </button>

            <% if (editEntry) { %>
              <a href="/track-screen-time" class="px-6 py-3 rounded-lg border border-slate-300 font-semibold hover:bg-slate-50 transition">
                Cancel
              </a>
            <% } %>
          </div>
        </form>
      </div>

      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-6">Live Session Tracking</h2>

        <div class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Category</label>
            <select id="sessionCategory" class="w-full border rounded-lg px-4 py-3">
              <option value="">Select category</option>
              <option value="Social Media">Social Media</option>
              <option value="Entertainment">Entertainment</option>
              <option value="Study">Study</option>
              <option value="Gaming">Gaming</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label class="block mb-2 font-medium">Notes</label>
            <input
              type="text"
              id="sessionNotes"
              placeholder="Optional notes for this session"
              class="w-full border rounded-lg px-4 py-3"
            >
          </div>

          <div class="p-6 rounded-xl bg-slate-50 border border-slate-200">
            <p class="text-sm text-slate-500 mb-2">Session Timer</p>
            <p id="liveTimer" class="text-4xl font-bold text-indigo-700">00:00:00</p>
          </div>

          <div class="mt-2 p-4 bg-indigo-50 rounded-lg text-center border border-indigo-100">
            <p id="motivationText" class="text-indigo-700 font-semibold">
              Ready to start your session 🚀
            </p>
          </div>

          <div class="flex gap-3">
            <button id="startBtn" type="button" class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition">
              Start Tracking
            </button>
            <button id="stopBtn" type="button" class="bg-red-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-600 transition" disabled>
              Stop Tracking
            </button>
          </div>

          <div id="sessionMessage" class="hidden p-4 rounded-lg border"></div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
      <h2 class="text-2xl font-bold mb-6">Your Entries</h2>

      <% if (entries && entries.length > 0) { %>
        <div class="space-y-4">
          <% entries.forEach(entry => { %>
            <div class="border rounded-xl p-4 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
              <div>
                <p><strong>Category:</strong> <%= entry.category %></p>
                <p><strong>Hours:</strong> <%= entry.hours %></p>
                <p><strong>Notes:</strong> <%= entry.notes || "No notes" %></p>
                <p><strong>Date:</strong> <%= new Date(entry.date).toLocaleDateString() %></p>
              </div>

              <div class="flex gap-3">
                <a href="/track-screen-time/edit/<%= entry._id %>" class="px-4 py-2 rounded-lg bg-yellow-500 text-white font-semibold hover:bg-yellow-600 transition">
                  Edit
                </a>

                <form action="/track-screen-time/delete/<%= entry._id %>" method="POST" onsubmit="return confirm('Delete this entry?')">
                  <button type="submit" class="px-4 py-2 rounded-lg bg-red-500 text-white font-semibold hover:bg-red-600 transition">
                    Delete
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-slate-500">No entries added yet.</p>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    socket.on("screenTimeUpdated", function () {
      window.location.reload();
    });

    const startBtn = document.getElementById("startBtn");
    const stopBtn = document.getElementById("stopBtn");
    const liveTimer = document.getElementById("liveTimer");
    const sessionCategory = document.getElementById("sessionCategory");
    const sessionNotes = document.getElementById("sessionNotes");
    const sessionMessage = document.getElementById("sessionMessage");
    const motivationText = document.getElementById("motivationText");
    const sessionStatus = document.getElementById("sessionStatus");

    let trackingStartTime = null;
    let timerInterval = null;
    let totalSeconds = 0;

    const messages = [
      "Stay focused 💪",
      "You are doing great 👍",
      "Keep going 🚀",
      "Avoid distractions 📵",
      "Take a short break soon 🧘"
    ];

    function randomMessage() {
      return messages[Math.floor(Math.random() * messages.length)];
    }

    function showMessage(text, isSuccess) {
      sessionMessage.className = "p-4 rounded-lg border";
      sessionMessage.classList.remove("hidden");

      if (isSuccess) {
        sessionMessage.classList.add("bg-green-100", "text-green-700", "border-green-200");
      } else {
        sessionMessage.classList.add("bg-red-100", "text-red-700", "border-red-200");
      }

      sessionMessage.textContent = text;
    }

    function formatTime(totalSeconds) {
      const hrs = String(Math.floor(totalSeconds / 3600)).padStart(2, "0");
      const mins = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, "0");
      const secs = String(totalSeconds % 60).padStart(2, "0");
      return `${hrs}:${mins}:${secs}`;
    }

    function startTracking() {
      const category = sessionCategory.value;

      if (!category) {
        showMessage("Please select a category before starting tracking.", false);
        return;
      }

      trackingStartTime = Date.now();
      totalSeconds = 0;

      sessionMessage.classList.add("hidden");

      sessionStatus.textContent = "Running";
      sessionStatus.className = "text-2xl font-bold text-green-600";

      motivationText.textContent = "Session started 🚀";
      motivationText.className = "text-indigo-700 font-semibold";

      startBtn.disabled = true;
      stopBtn.disabled = false;
      sessionCategory.disabled = true;
      sessionNotes.disabled = true;

      timerInterval = setInterval(() => {
        totalSeconds++;
        liveTimer.textContent = formatTime(totalSeconds);

        if (totalSeconds % 10 === 0) {
          motivationText.textContent = randomMessage();
          motivationText.className = "text-indigo-700 font-semibold";
        }

        const hours = totalSeconds / 3600;

        if (hours > 3.5) {
          motivationText.textContent = "⚠️ You are close to your daily limit!";
          motivationText.className = "text-yellow-600 font-bold";
        }

        if (hours > 4) {
          motivationText.textContent = "🚨 Limit exceeded! Consider stopping.";
          motivationText.className = "text-red-600 font-bold";
        }
      }, 1000);
    }

    async function stopTracking() {
      if (!trackingStartTime) return;

      clearInterval(timerInterval);

      const minutes = totalSeconds / 60;

      sessionStatus.textContent = "Stopped";
      sessionStatus.className = "text-2xl font-bold text-red-500";

      motivationText.textContent = "Session completed ✅";
      motivationText.className = "text-green-700 font-bold";

      try {
        const response = await fetch("/track-screen-time/session", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            category: sessionCategory.value,
            minutes,
            notes: sessionNotes.value
          })
        });

        const result = await response.json();

        if (!response.ok) {
          showMessage(result.message || "Failed to save tracked session.", false);
        } else {
          showMessage("Session saved successfully 🎉", true);
          liveTimer.textContent = "00:00:00";
          trackingStartTime = null;
          sessionCategory.disabled = false;
          sessionNotes.disabled = false;
          sessionCategory.value = "";
          sessionNotes.value = "";
        }
      } catch (error) {
        console.error(error);
        showMessage("Something went wrong while saving the session.", false);
      } finally {
        startBtn.disabled = false;
        stopBtn.disabled = true;
      }
    }

    startBtn.addEventListener("click", startTracking);
    stopBtn.addEventListener("click", stopTracking);
  </script>
</body>
</html>