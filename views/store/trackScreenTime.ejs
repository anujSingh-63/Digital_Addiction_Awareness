<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Activity Tracking</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <%
    function formatTime(value) {
      const h = Math.floor(value || 0);
      const m = Math.round(((value || 0) % 1) * 60);
      return `${h}h ${m}m`;
    }
  %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Activity Tracking</h1>
      <p class="text-slate-600">Track live sessions, review today’s activity, and stay within your limits.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-700 border border-red-200">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-700 border border-green-200">
        <%= success %>
      </div>
    <% } %>

    <div class="grid md:grid-cols-2 xl:grid-cols-5 gap-4 mb-8">
      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Today’s Usage</p>
        <p id="todayUsageValue" class="text-2xl font-bold text-indigo-700"><%= todayTotal %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Time Left</p>
        <p id="timeLeftValue" class="text-2xl font-bold text-green-700"><%= timeLeft %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Sessions Today</p>
        <p class="text-2xl font-bold text-blue-700"><%= sessionCount %></p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Most Used</p>
        <p class="text-2xl font-bold text-purple-700"><%= mostUsedCategory %></p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Status</p>
        <p id="usageStatusValue" class="text-2xl font-bold <%= usageStatus === 'Healthy' ? 'text-green-600' : usageStatus === 'Approaching Limit' ? 'text-yellow-600' : 'text-red-600' %>">
          <%= usageStatus %>
        </p>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold">Daily Limit Progress</h2>
        <span id="progressLabel" class="text-sm font-semibold text-slate-600"><%= todayTotal %> / <%= dailyLimit %> hrs</span>
      </div>

      <div class="w-full bg-slate-200 rounded-full h-4 overflow-hidden">
        <div
          id="dailyProgressBar"
          class="h-4 rounded-full <%= usageStatus === 'Healthy' ? 'bg-green-500' : usageStatus === 'Approaching Limit' ? 'bg-yellow-500' : 'bg-red-500' %>"
          style="width: <%= progressPercent %>";
        ></div>
      </div>

      <div class="flex flex-wrap gap-3 mt-4 text-sm">
        <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 font-semibold">
          Warning: <%= formatTime(warningLimit) %>
        </span>
        <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 font-semibold">
          Danger: <%= formatTime(dangerLimit) %>
        </span>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 mb-8">
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold">Live Session</h2>
          <span id="sessionStatus" class="px-3 py-1 rounded-full bg-slate-100 text-slate-700 font-semibold">
            Idle
          </span>
        </div>

        <div class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Category</label>
            <select id="sessionCategory" class="w-full border rounded-lg px-4 py-3">
              <option value="">Select category</option>
              <option value="Social Media">Social Media</option>
              <option value="Entertainment">Entertainment</option>
              <option value="Study">Study</option>
              <option value="Gaming">Gaming</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label class="block mb-2 font-medium">Notes</label>
            <input
              type="text"
              id="sessionNotes"
              placeholder="Optional notes for this session"
              class="w-full border rounded-lg px-4 py-3"
            >
          </div>

          <div class="p-6 rounded-xl bg-slate-50 border border-slate-200 text-center">
            <p class="text-sm text-slate-500 mb-2">Session Timer</p>
            <p id="liveTimer" class="text-5xl font-bold text-indigo-700">00:00:00</p>
          </div>

          <div class="mt-2 p-4 bg-indigo-50 rounded-lg text-center border border-indigo-100">
            <p id="motivationText" class="text-indigo-700 font-semibold">
              Start a live session to begin tracking.
            </p>
          </div>

          <div class="flex gap-3">
            <button id="startBtn" type="button" class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition">
              Start Session
            </button>
            <button id="stopBtn" type="button" class="bg-red-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-600 transition" disabled>
              Stop Session
            </button>
          </div>

          <div id="sessionMessage" class="hidden p-4 rounded-lg border"></div>
        </div>
      </div>

      <!-- 🔥 COMBINED LIVE TRACKING - SYSTEM APPS + WEBSITES -->
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-4">🎯 Live Activity Tracking</h2>
        
        <!-- Current Active App -->
        <div class="mb-6 p-4 rounded-lg bg-blue-50 border border-blue-200">
          <p class="text-xs text-blue-600 font-semibold mb-2">CURRENTLY ACTIVE</p>
          <div id="currentApp" class="text-lg font-bold text-blue-900">
            <p>⏳ Waiting for data...</p>
          </div>
        </div>

        <!-- Current Active Website -->
        <div class="mb-6 p-4 rounded-lg bg-green-50 border border-green-200">
          <p class="text-xs text-green-600 font-semibold mb-2">CURRENT WEBSITE</p>
          <div id="currentWebsite" class="text-lg font-bold text-green-900">
            <p>⏳ Waiting for website data...</p>
          </div>
        </div>

        <!-- Combined Activity History -->
        <div id="liveActivityData" class="space-y-2 text-slate-700">
          <p class="text-slate-500">Loading activity data...</p>
        </div>
      </div>

      <!-- 🌐 WEBSITE TRACKING (LEGACY - CAN BE REMOVED) -->
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6" style="display:none;">
        <h2 class="text-2xl font-bold mb-4">🌐 Live Websites</h2>

        <div id="websiteData" class="space-y-2 text-slate-700">
          <p class="text-slate-500">Loading website data...</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-6"><%= editEntry ? "Edit Activity Entry" : "Manual Entry" %></h2>

        <form action="<%= editEntry ? '/track-screen-time/update/' + editEntry._id : '/track-screen-time' %>" method="POST" class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Category</label>
            <select name="category" class="w-full border rounded-lg px-4 py-3" required>
              <option value="">Select category</option>
              <option value="Social Media" <%= editEntry && editEntry.category === 'Social Media' ? 'selected' : '' %>>Social Media</option>
              <option value="Entertainment" <%= editEntry && editEntry.category === 'Entertainment' ? 'selected' : '' %>>Entertainment</option>
              <option value="Study" <%= editEntry && editEntry.category === 'Study' ? 'selected' : '' %>>Study</option>
              <option value="Gaming" <%= editEntry && editEntry.category === 'Gaming' ? 'selected' : '' %>>Gaming</option>
              <option value="Other" <%= editEntry && editEntry.category === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>

          <div>
            <label class="block mb-2 font-medium">Hours</label>
            <input
              type="number"
              name="hours"
              step="0.1"
              min="0"
              max="24"
              value="<%= editEntry ? editEntry.hours : '' %>"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Notes</label>
            <input
              type="text"
              name="notes"
              placeholder="Optional notes"
              value="<%= editEntry ? editEntry.notes : '' %>"
              class="w-full border rounded-lg px-4 py-3"
            >
          </div>

          <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
              <%= editEntry ? "Update Entry" : "Save Manual Entry" %>
            </button>

            <% if (editEntry) { %>
              <a href="/track-screen-time" class="px-6 py-3 rounded-lg border border-slate-300 font-semibold hover:bg-slate-50 transition">
                Cancel
              </a>
            <% } %>
          </div>
        </form>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6 mb-8">
      <h2 class="text-2xl font-bold mb-6">Today’s Session History</h2>

      <% if (todayEntries && todayEntries.length > 0) { %>
        <div class="space-y-4">
          <% todayEntries.forEach(entry => { %>
            <div class="border rounded-xl p-4 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
              <div>
                <p><strong>Category:</strong> <%= entry.category %></p>
                <p><strong>Hours:</strong> <%= entry.hours %></p>
                <p><strong>Notes:</strong> <%= entry.notes || "No notes" %></p>
                <p><strong>Time:</strong> <%= new Date(entry.createdAt).toLocaleString() %></p>
              </div>

              <div class="flex gap-3">
                <a href="/track-screen-time/edit/<%= entry._id %>" class="px-4 py-2 rounded-lg bg-yellow-500 text-white font-semibold hover:bg-yellow-600 transition">
                  Edit
                </a>

                <form action="/track-screen-time/delete/<%= entry._id %>" method="POST" onsubmit="return confirm('Delete this entry?')">
                  <button type="submit" class="px-4 py-2 rounded-lg bg-red-500 text-white font-semibold hover:bg-red-600 transition">
                    Delete
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-slate-500">No activity sessions recorded today.</p>
      <% } %>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
      <h2 class="text-2xl font-bold mb-6">All Activity Records</h2>

      <% if (entries && entries.length > 0) { %>
        <div class="space-y-4">
          <% entries.forEach(entry => { %>
            <div class="border rounded-xl p-4">
              <p><strong>Category:</strong> <%= entry.category %></p>
              <p><strong>Hours:</strong> <%= entry.hours %></p>
              <p><strong>Notes:</strong> <%= entry.notes || "No notes" %></p>
              <p><strong>Date:</strong> <%= new Date(entry.date).toLocaleDateString() %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-slate-500">No activity records found.</p>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>
  <%- include("../partials/toast", { userId }) %>
  <script>
    // Socket.io is already initialized in toast.ejs
    socket.on("screenTimeUpdated", function (){
      window.location.reload();
    });

    const startBtn = document.getElementById("startBtn");
    const stopBtn = document.getElementById("stopBtn");
    const liveTimer = document.getElementById("liveTimer");
    const sessionCategory = document.getElementById("sessionCategory");
    const sessionNotes = document.getElementById("sessionNotes");
    const sessionMessage = document.getElementById("sessionMessage");
    const motivationText = document.getElementById("motivationText");
    const sessionStatus = document.getElementById("sessionStatus");

    const todayUsageValue = document.getElementById("todayUsageValue");
    const timeLeftValue = document.getElementById("timeLeftValue");
    const usageStatusValue = document.getElementById("usageStatusValue");
    const progressLabel = document.getElementById("progressLabel");
    const dailyProgressBar = document.getElementById("dailyProgressBar");

    const baseTodayTotal = <%- JSON.stringify(todayTotal || 0) %>;
    const dailyLimit = <%- JSON.stringify(dailyLimit || 0) %>;
    const warningLimit = <%- JSON.stringify(warningLimit || 0) %>;
    const dangerLimit = <%- JSON.stringify(dangerLimit || 0) %>;

    let timerInterval = null;
    let liveWarningShown = false;
    let liveDangerShown = false;

    const messages = [
      "Stay focused 💪",
      "You are doing great 👍",
      "Keep going 🚀",
      "Avoid distractions 📵",
      "Take a short break soon 🧘"
    ];

    function randomMessage() {
      return messages[Math.floor(Math.random() * messages.length)];
    }

    function showMessage(text, isSuccess) {
      sessionMessage.className = "p-4 rounded-lg border";
      sessionMessage.classList.remove("hidden");

      if (isSuccess) {
        sessionMessage.classList.add("bg-green-100", "text-green-700", "border-green-200");
      } else {
        sessionMessage.classList.add("bg-red-100", "text-red-700", "border-red-200");
      }

      sessionMessage.textContent = text;
    }

    function formatClock(totalSeconds) {
      const hrs = String(Math.floor(totalSeconds / 3600)).padStart(2, "0");
      const mins = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, "0");
      const secs = String(totalSeconds % 60).padStart(2, "0");
      return `${hrs}:${mins}:${secs}`;
    }

    // Get current date as YYYY-MM-DD for daily reset
    function getCurrentDate() {
      const today = new Date();
      return today.toISOString().split('T')[0];
    }

    function getSession() {
      const raw = localStorage.getItem("activeSession");
      return raw ? JSON.parse(raw) : null;
    }

    function saveSession(data) {
      // Add date tracking for daily reset
      const sessionData = {
        ...data,
        sessionDate: getCurrentDate() // Store the date when session was created
      };
      localStorage.setItem("activeSession", JSON.stringify(sessionData));
    }

    function clearSession() {
      localStorage.removeItem("activeSession");
    }

    // Check if session belongs to a different day
    function isSessionFromDifferentDay(session) {
      if (!session || !session.sessionDate) return false;
      const currentDate = getCurrentDate();
      return session.sessionDate !== currentDate;
    }

    function getStatusByTotal(totalHours) {
      if (totalHours < warningLimit) return "Healthy";
      if (totalHours >= warningLimit && totalHours < dangerLimit) return "Approaching Limit";
      return "Limit Reached";
    }

    function applyStatusStyle(status) {
      usageStatusValue.textContent = status;
      usageStatusValue.className = "text-2xl font-bold";

      dailyProgressBar.classList.remove("bg-green-500", "bg-yellow-500", "bg-red-500");

      if (status === "Healthy") {
        usageStatusValue.classList.add("text-green-600");
        dailyProgressBar.classList.add("bg-green-500");
      } else if (status === "Approaching Limit") {
        usageStatusValue.classList.add("text-yellow-600");
        dailyProgressBar.classList.add("bg-yellow-500");
      } else {
        usageStatusValue.classList.add("text-red-600");
        dailyProgressBar.classList.add("bg-red-500");
      }
    }

    function updateLiveOverview(sessionSeconds) {
      const sessionHours = sessionSeconds / 3600;
      const combinedTodayTotal = baseTodayTotal + sessionHours;
      const timeLeft = Math.max(dailyLimit - combinedTodayTotal, 0);
      const progressPercent = Math.min((combinedTodayTotal / dailyLimit) * 100, 100);
      const status = getStatusByTotal(combinedTodayTotal);

      todayUsageValue.textContent = `${combinedTodayTotal.toFixed(2)} hrs`;
      timeLeftValue.textContent = `${timeLeft.toFixed(2)} hrs`;
      progressLabel.textContent = `${combinedTodayTotal.toFixed(2)} / ${dailyLimit} hrs`;
      dailyProgressBar.style.width = `${progressPercent}%`;

      applyStatusStyle(status);
    }

    function resetOverviewToServerValues() {
      todayUsageValue.textContent = `${baseTodayTotal} hrs`;
      timeLeftValue.textContent = `${Math.max(dailyLimit - baseTodayTotal, 0).toFixed(2)} hrs`;
      progressLabel.textContent = `${baseTodayTotal} / ${dailyLimit} hrs`;
      dailyProgressBar.style.width = `${Math.min((baseTodayTotal / dailyLimit) * 100, 100)}%`;

      applyStatusStyle(getStatusByTotal(baseTodayTotal));
    }

    function showLiveToast(message, type) {
      if (typeof createToast === "function") {
        createToast(message, type);
      }
    }

    function startTimer(startTime) {
      clearInterval(timerInterval);

      timerInterval = setInterval(() => {
        const totalSeconds = Math.floor((Date.now() - startTime) / 1000);
        liveTimer.textContent = formatClock(totalSeconds);
        updateLiveOverview(totalSeconds);

        if (totalSeconds > 0 && totalSeconds % 10 === 0 && !liveDangerShown) {
          motivationText.textContent = randomMessage();
          motivationText.className = "text-indigo-700 font-semibold";
        }

        const sessionHours = totalSeconds / 3600;

        if (!liveWarningShown && sessionHours >= warningLimit && sessionHours < dangerLimit) {
          liveWarningShown = true;
          motivationText.textContent = "⚠️ Warning threshold reached";
          motivationText.className = "text-yellow-700 font-bold";
          showLiveToast(`Live warning: you reached ${warningLimit.toFixed(2)} hrs in this session.`, "warning");
        }

        if (!liveDangerShown && sessionHours >= dangerLimit) {
          liveDangerShown = true;
          motivationText.textContent = "🚨 Danger threshold reached";
          motivationText.className = "text-red-700 font-bold";
          showLiveToast(`Live danger: you reached ${dangerLimit.toFixed(2)} hrs in this session.`, "danger");
        }
      }, 1000);
    }

    function startTracking() {
      const category = sessionCategory.value;

      if (!category) {
        showMessage("Please select a category before starting the session.", false);
        return;
      }

      liveWarningShown = false;
      liveDangerShown = false;

      const sessionData = {
        startTime: Date.now(),
        category,
        notes: sessionNotes.value || "",
        liveWarningShown: false,
        liveDangerShown: false,
        sessionDate: getCurrentDate() // Track the date
      };

      saveSession(sessionData);
      startTimer(sessionData.startTime);

      sessionMessage.classList.add("hidden");
      sessionStatus.textContent = "Live";
      sessionStatus.className = "px-3 py-1 rounded-full bg-green-100 text-green-700 font-semibold";

      motivationText.textContent = "Live session started 🚀";
      motivationText.className = "text-indigo-700 font-semibold";

      startBtn.disabled = true;
      stopBtn.disabled = false;
      sessionCategory.disabled = true;
      sessionNotes.disabled = true;
    
    }
      function restoreSession() {
        const session = getSession();
        
        // Check if session is from a different day
        if (session && isSessionFromDifferentDay(session)) {
          console.log("🔄 Day changed detected! Clearing old session.");
          clearSession();
          resetOverviewToServerValues();
          return;
        }
        
        if (!session) {
          resetOverviewToServerValues();
          return;
        }

        // Calculate how much time has passed since session started
        const timeSinceStart = Date.now() - session.startTime;
        const maxSessionTime = 24 * 60 * 60 * 1000; // 24 hours in milliseconds
        
        // If session is older than 24 hours, it's from before a system shutdown
        // Clear it as it's likely stale
        if (timeSinceStart > maxSessionTime) {
          console.log("🔄 Session is older than 24 hours. Clearing stale session.");
          clearSession();
          resetOverviewToServerValues();
          return;
        }

        sessionCategory.value = session.category || "";
        sessionNotes.value = session.notes || "";

        sessionCategory.disabled = true;
        sessionNotes.disabled = true;

        startBtn.disabled = true;
        stopBtn.disabled = false;

        sessionStatus.textContent = "Live";
        sessionStatus.className = "px-3 py-1 rounded-full bg-green-100 text-green-700 font-semibold";

        liveWarningShown = Boolean(session.liveWarningShown);
        liveDangerShown = Boolean(session.liveDangerShown);

        // Restore the timer with the original startTime
        startTimer(session.startTime);
        
        console.log("✅ Session restored from " + new Date(session.startTime).toLocaleTimeString());
      }
    

    async function stopTracking() {
      const session = getSession();
      if (!session) return;

      clearInterval(timerInterval);

      const totalSeconds = Math.floor((Date.now() - session.startTime) / 1000);
      const minutes = totalSeconds / 60;

      sessionStatus.textContent = "Idle";
      sessionStatus.className = "px-3 py-1 rounded-full bg-slate-100 text-slate-700 font-semibold";

      motivationText.textContent = "Session completed ✅";
      motivationText.className = "text-green-700 font-bold";

      try {
        const response = await fetch("/track-screen-time/session", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            category: session.category,
            minutes,
            notes: session.notes
          })
        });

        const result = await response.json();

        if (!response.ok) {
          showMessage(result.message || "Failed to save session.", false);
        } else {
          showMessage("Session saved successfully 🎉", true);
          clearSession();
          liveTimer.textContent = "00:00:00";
          resetOverviewToServerValues();
        }
      } catch (error) {
        console.error(error);
        showMessage("Something went wrong while saving the session.", false);
      } finally {
        startBtn.disabled = false;
        stopBtn.disabled = true;
        sessionCategory.disabled = false;
        sessionNotes.disabled = false;
        sessionCategory.value = "";
        sessionNotes.value = "";
        liveWarningShown = false;
        liveDangerShown = false;
      }
    }

    // Periodically save session state (every 5 seconds)
    setInterval(function() {
      const session = getSession();
      if (session) {
        session.liveWarningShown = liveWarningShown;
        session.liveDangerShown = liveDangerShown;
        saveSession(session);
      }
    }, 5000);

    document.addEventListener("visibilitychange", function () {
      const session = getSession();
      if (!session) return;
      
      // Check if day changed while tab was hidden
      if (isSessionFromDifferentDay(session)) {
        console.log("🔄 Day changed while tab was hidden. Clearing session.");
        clearSession();
        location.reload();
        return;
      }

      session.liveWarningShown = liveWarningShown;
      session.liveDangerShown = liveDangerShown;
      saveSession(session);
    });

    window.addEventListener("beforeunload", function () {
      const session = getSession();
      if (!session) return;

      session.liveWarningShown = liveWarningShown;
      session.liveDangerShown = liveDangerShown;
      saveSession(session);
      console.log("💾 Session saved before unload");
    });

    // Check for day change periodically (every minute)
    setInterval(function() {
      const session = getSession();
      if (session && isSessionFromDifferentDay(session)) {
        console.log("🔄 Day changed detected! Reloading page.");
        clearSession();
        location.reload();
      }
    }, 60000);

    restoreSession();

    // Attach event listeners with proper error handling
    if (startBtn) {
      startBtn.addEventListener("click", function(e) {
        e.preventDefault();
        console.log("Start button clicked"); // Debug log
        startTracking();
      });
    }

    if (stopBtn) {
      stopBtn.addEventListener("click", function(e) {
        e.preventDefault();
        console.log("Stop button clicked"); // Debug log
        stopTracking();
      });
    }

    //  COMBINED LIVE TRACKING DISPLAY (APPS + WEBSITES)
    function loadLiveActivityData() {
      Promise.all([
        fetch("/api/system-app-data").then(r => r.json()),
        fetch("/api/website-data").then(r => r.json())
      ])
      .then(([appData, websiteData]) => {
        const container = document.getElementById("liveActivityData");
        const currentAppContainer = document.getElementById("currentApp");
        const currentWebsiteContainer = document.getElementById("currentWebsite");

        // Show current app
        if (appData && appData.length > 0) {
          const latestApp = appData[appData.length - 1];
          const timeDisplay = latestApp.timeSpent >= 60 
            ? `${Math.floor(latestApp.timeSpent / 60)}m ${latestApp.timeSpent % 60}s` 
            : `${latestApp.timeSpent}s`;

          currentAppContainer.innerHTML = `
            <div class="space-y-2">
              <p class="text-sm">
                <span class="text-blue-900 font-bold">📍 App:</span> 
                <span class="text-blue-800">${latestApp.appName || "Unknown"}</span>
              </p>
              <p class="text-sm">
                <span class="text-blue-900 font-bold">⏱️ Duration:</span> 
                <span class="text-blue-800">${timeDisplay}</span>
              </p>
              <p class="text-xs text-blue-600">🕐 ${new Date(latestApp.timestamp).toLocaleTimeString()}</p>
            </div>
          `;
        }

        // Show current website
        if (websiteData && websiteData.length > 0) {
          const latestWebsite = websiteData[websiteData.length - 1];
          const favicon = `https://www.google.com/s2/favicons?sz=16&domain=${latestWebsite.website}`;
          const timeDisplay = latestWebsite.timeSpent >= 60 
            ? `${Math.floor(latestWebsite.timeSpent / 60)}m ${latestWebsite.timeSpent % 60}s` 
            : `${latestWebsite.timeSpent}s`;

          currentWebsiteContainer.innerHTML = `
            <div class="space-y-2">
              <div class="flex items-center gap-2 mb-2">
                <img src="${favicon}" alt="${latestWebsite.website}" class="w-5 h-5" onerror="this.style.display='none'" />
                <p class="text-sm">
                  <span class="text-green-900 font-bold">🌐 Website:</span> 
                  <span class="text-green-800">${latestWebsite.website}</span>
                </p>
              </div>
              <p class="text-sm">
                <span class="text-green-900 font-bold">🔗 URL:</span> 
                <span class="text-green-800 text-xs break-all">${latestWebsite.url}</span>
              </p>
              <p class="text-sm">
                <span class="text-green-900 font-bold">⏱️ Duration:</span> 
                <span class="text-green-800">${timeDisplay}</span>
              </p>
              <p class="text-xs text-green-600">🕐 ${new Date(latestWebsite.timestamp).toLocaleTimeString()}</p>
            </div>
          `;
        }

        // Combined history
        let html = `<div class="mb-4 p-3 bg-slate-100 rounded-lg border border-slate-300">
          <p class="text-xs font-bold text-slate-700 mb-3">📊 COMBINED ACTIVITY HISTORY</p>`;

        // Merge and sort by timestamp (most recent first)
        const allItems = [];
        
        if (appData && appData.length > 0) {
          appData.forEach(item => {
            allItems.push({
              type: 'app',
              name: item.appName,
              time: item.timeSpent,
              timestamp: new Date(item.timestamp),
              display: item.appName
            });
          });
        }
        
        if (websiteData && websiteData.length > 0) {
          websiteData.forEach(item => {
            allItems.push({
              type: 'website',
              name: item.website,
              url: item.url,
              time: item.timeSpent,
              timestamp: new Date(item.timestamp),
              display: item.website
            });
          });
        }

        // Sort by timestamp descending
        allItems.sort((a, b) => b.timestamp - a.timestamp);

        // Show last 15 items
        allItems.slice(0, 15).forEach((item, idx) => {
          const timeDisplay = item.time >= 60 
            ? `${Math.floor(item.time / 60)}m ${item.time % 60}s` 
            : `${item.time}s`;
          
          const timestamp = item.timestamp.toLocaleTimeString();
          const icon = item.type === 'app' ? '📱' : '🌐';
          const borderColor = item.type === 'app' ? 'border-blue-500 bg-blue-50' : 'border-green-500 bg-green-50';
          
          html += `
            <div class="p-2 mb-2 border-l-4 ${borderColor} rounded">
              <div class="flex justify-between items-start">
                <div>
                  <p class="font-semibold text-slate-800">${idx + 1}. ${icon} ${item.display}</p>
                  <p class="text-xs text-slate-600">🕐 ${timestamp}</p>
                  ${item.type === 'website' ? `<p class="text-xs text-slate-500 truncate">🔗 ${item.url}</p>` : ''}
                </div>
                <span class="px-3 py-1 ${item.type === 'app' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'} rounded font-bold text-sm">
                  ${timeDisplay}
                </span>
              </div>
            </div>
          `;
        });

        html += `</div>`;
        container.innerHTML = html;
      })
      .catch(err => {
        console.error("Error loading activity data:", err);
        document.getElementById("liveActivityData").innerHTML = "<p class='text-red-500'>❌ Error loading data</p>";
      });
    }

    // Load combined activity data immediately and refresh every 3 seconds
    loadLiveActivityData();
    
    setInterval(() => {
      loadLiveActivityData();
    }, 3000);

    // Socket.io connection for real-time updates
    socket.on("screenTimeUpdated", function (){
      window.location.reload();
    });
  </script>
</body>
</html>