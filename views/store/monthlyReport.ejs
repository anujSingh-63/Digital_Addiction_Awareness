<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monthly Report - Activity Tracking</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-slate-900">📈 Monthly Report</h1>
      <p class="text-slate-600 mt-2"><%= monthName %> - Activity Analysis</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-700 border border-red-200">
        <%= error %>
      </div>
    <% } %>

    <!-- Stats Cards -->
    <div class="grid md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-600 mb-2">Total Usage</p>
        <p class="text-3xl font-bold text-indigo-600"><%= totalHours %> hrs</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-600 mb-2">Average Daily</p>
        <p class="text-3xl font-bold text-blue-600"><%= averageDaily %> hrs</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-600 mb-2">Total Sessions</p>
        <p class="text-3xl font-bold text-green-600"><%= records.length %></p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-600 mb-2">Most Used Category</p>
        <p class="text-3xl font-bold text-purple-600"><%= topCategory %></p>
      </div>
    </div>

    <!-- Charts -->
    <div class="grid lg:grid-cols-2 gap-8 mb-8">
      <!-- Weekly Breakdown Chart -->
      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <h2 class="text-2xl font-bold mb-6">📊 Weekly Breakdown</h2>
        <div style="position: relative; height: 300px;">
          <canvas id="weeklyChart"></canvas>
        </div>
      </div>

      <!-- Category Distribution -->
      <div class="bg-white p-6 rounded-2xl shadow border border-slate-200">
        <h2 class="text-2xl font-bold mb-6">🎯 Category Total</h2>
        <div style="position: relative; height: 300px;">
          <canvas id="categoryChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Weekly Details -->
    <div class="bg-white p-6 rounded-2xl shadow border border-slate-200 mb-8">
      <h2 class="text-2xl font-bold mb-6">📋 Weekly Breakdown</h2>
      
      <div class="space-y-4">
        <% weeklyData.forEach((week, index) => { %>
          <div class="p-4 border rounded-lg hover:bg-slate-50 transition">
            <div class="flex justify-between items-center mb-3">
              <h3 class="font-bold text-lg"><%= week[0] %></h3>
              <span class="px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 font-bold">
                <%= week[1].total.toFixed(2) %> hrs
              </span>
            </div>
            
            <div class="grid grid-cols-5 gap-2 text-sm">
              <div class="p-2 bg-indigo-50 rounded">
                <p class="text-slate-600">Social Media</p>
                <p class="font-bold text-indigo-600"><%= week[1]["Social Media"].toFixed(2) %> hrs</p>
              </div>
              <div class="p-2 bg-pink-50 rounded">
                <p class="text-slate-600">Entertainment</p>
                <p class="font-bold text-pink-600"><%= week[1].Entertainment.toFixed(2) %> hrs</p>
              </div>
              <div class="p-2 bg-teal-50 rounded">
                <p class="text-slate-600">Study</p>
                <p class="font-bold text-teal-600"><%= week[1].Study.toFixed(2) %> hrs</p>
              </div>
              <div class="p-2 bg-orange-50 rounded">
                <p class="text-slate-600">Gaming</p>
                <p class="font-bold text-orange-600"><%= week[1].Gaming.toFixed(2) %> hrs</p>
              </div>
              <div class="p-2 bg-purple-50 rounded">
                <p class="text-slate-600">Other</p>
                <p class="font-bold text-purple-600"><%= week[1].Other.toFixed(2) %> hrs</p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Download Options -->
    <div class="mt-8 bg-white p-6 rounded-2xl shadow border border-slate-200">
      <h3 class="text-xl font-bold mb-4">📥 Download Report</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <button onclick="downloadReport('pdf')" class="flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-red-600 text-white font-semibold hover:bg-red-700 transition">
          <i class="fas fa-file-pdf"></i> Download as PDF
        </button>
        <button onclick="downloadReport('csv')" class="flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-700 transition">
          <i class="fas fa-file-csv"></i> Download as CSV
        </button>
      </div>
    </div>

    <!-- Navigation Links -->
    <div class="mt-8 flex gap-4 justify-center">
      <a href="/daily-report" class="px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
        📊 Daily Report
      </a>
      <a href="/weekly-report" class="px-6 py-3 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
        📊 Weekly Report
      </a>
      <a href="/track-screen-time" class="px-6 py-3 rounded-lg bg-slate-600 text-white font-semibold hover:bg-slate-700 transition">
        ← Back to Tracking
      </a>
    </div>

    <script>
      function downloadReport(format) {
        window.location.href = `/monthly-report/download?format=${format}`;
      }
    </script>
  </div>

  <%- include("../partials/footer") %>

  <script>
    const monthlyTotals = <%- JSON.stringify(monthlyTotals) %>;
    
    const weeklyLabels = <%- JSON.stringify(weeklyData.map(w => w[0])) %>;
    const weeklySocialMedia = <%- JSON.stringify(weeklyData.map(w => w[1]["Social Media"])) %>;
    const weeklyEntertainment = <%- JSON.stringify(weeklyData.map(w => w[1].Entertainment)) %>;
    const weeklyStudy = <%- JSON.stringify(weeklyData.map(w => w[1].Study)) %>;
    const weeklyGaming = <%- JSON.stringify(weeklyData.map(w => w[1].Gaming)) %>;
    const weeklyOther = <%- JSON.stringify(weeklyData.map(w => w[1].Other)) %>;

    // Weekly Bar Chart
    const weeklyCtx = document.getElementById('weeklyChart').getContext('2d');
    new Chart(weeklyCtx, {
      type: 'bar',
      data: {
        labels: weeklyLabels,
        datasets: [
          {
            label: 'Social Media',
            data: weeklySocialMedia,
            backgroundColor: '#6366f1'
          },
          {
            label: 'Entertainment',
            data: weeklyEntertainment,
            backgroundColor: '#ec4899'
          },
          {
            label: 'Study',
            data: weeklyStudy,
            backgroundColor: '#14b8a6'
          },
          {
            label: 'Gaming',
            data: weeklyGaming,
            backgroundColor: '#f97316'
          },
          {
            label: 'Other',
            data: weeklyOther,
            backgroundColor: '#8b5cf6'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { font: { size: 12 }, padding: 15 }
          }
        },
        scales: {
          x: { stacked: true },
          y: { stacked: true, beginAtZero: true }
        }
      }
    });

    // Category Pie Chart
    const categoryCtx = document.getElementById('categoryChart').getContext('2d');
    new Chart(categoryCtx, {
      type: 'pie',
      data: {
        labels: Object.keys(monthlyTotals),
        datasets: [{
          data: Object.values(monthlyTotals),
          backgroundColor: [
            '#6366f1',
            '#ec4899',
            '#14b8a6',
            '#f97316',
            '#8b5cf6'
          ],
          borderColor: 'white',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { font: { size: 12 }, padding: 20 }
          }
        }
      }
    });
  </script>
</body>
</html>
