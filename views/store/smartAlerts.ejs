<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Alerts - Digital Addiction Awareness</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900">Smart Alerts</h1>
        <p class="text-slate-600">
          Hello, <%= userName %>. Track warnings and notifications related to your screen usage.
        </p>
      </div>

      <div class="flex gap-3">
        <a href="/" class="px-4 py-2 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
          Dashboard
        </a>
        <a href="/track-screen-time" class="px-4 py-2 rounded-lg border border-slate-300 font-semibold hover:bg-slate-100 transition">
          Track Time
        </a>

        <% if (alerts && alerts.length > 0 && unreadCount > 0) { %>
          <form action="/smart-alerts/read-all" method="POST">
            <button type="submit" class="px-4 py-2 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-700 transition">
              Mark All Read
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-500 uppercase">Total Alerts</h2>
          <i class="fas fa-bell text-blue-500 text-xl"></i>
        </div>
        <p class="text-3xl font-bold text-slate-900"><%= totalCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-500 uppercase">Unread</h2>
          <i class="fas fa-envelope-open-text text-indigo-500 text-xl"></i>
        </div>
        <p class="text-3xl font-bold text-indigo-700"><%= unreadCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-500 uppercase">Warnings / Danger</h2>
          <i class="fas fa-triangle-exclamation text-red-500 text-xl"></i>
        </div>
        <p class="text-3xl font-bold text-red-600"><%= dangerCount + warningCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-slate-500 uppercase">Info Alerts</h2>
          <i class="fas fa-circle-info text-sky-500 text-xl"></i>
        </div>
        <p class="text-3xl font-bold text-sky-600"><%= infoCount %></p>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">Recent Alerts</h2>
        <% if (unreadCount > 0) { %>
          <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-sm font-semibold">
            <%= unreadCount %> unread
          </span>
        <% } %>
      </div>

      <% if (alerts && alerts.length > 0) { %>
        <div class="space-y-4">
          <% alerts.forEach(alert => { %>
            <div class="rounded-2xl border p-5 transition hover:shadow-md
              <%= alert.type === 'danger' ? 'bg-red-50 border-red-200' : '' %>
              <%= alert.type === 'warning' ? 'bg-yellow-50 border-yellow-200' : '' %>
              <%= alert.type === 'info' ? 'bg-blue-50 border-blue-200' : '' %>
              <%= alert.isRead ? 'opacity-80' : 'ring-1 ring-offset-1 ring-slate-200' %>
            ">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                <div class="flex gap-4">
                  <div class="w-12 h-12 rounded-full flex items-center justify-center
                    <%= alert.type === 'danger' ? 'bg-red-100 text-red-600' : '' %>
                    <%= alert.type === 'warning' ? 'bg-yellow-100 text-yellow-600' : '' %>
                    <%= alert.type === 'info' ? 'bg-blue-100 text-blue-600' : '' %>
                  ">
                    <% if (alert.type === "danger") { %>
                      <i class="fas fa-triangle-exclamation text-xl"></i>
                    <% } else if (alert.type === "warning") { %>
                      <i class="fas fa-bell text-xl"></i>
                    <% } else { %>
                      <i class="fas fa-circle-info text-xl"></i>
                    <% } %>
                  </div>

                  <div>
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      <h3 class="font-bold text-slate-900"><%= alert.message %></h3>

                      <span class="text-xs px-3 py-1 rounded-full font-semibold
                        <%= alert.type === 'danger' ? 'bg-red-100 text-red-700' : '' %>
                        <%= alert.type === 'warning' ? 'bg-yellow-100 text-yellow-700' : '' %>
                        <%= alert.type === 'info' ? 'bg-blue-100 text-blue-700' : '' %>
                      ">
                        <%= alert.type %>
                      </span>

                      <% if (!alert.isRead) { %>
                        <span class="text-xs px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 font-semibold">
                          Unread
                        </span>
                      <% } else { %>
                        <span class="text-xs px-3 py-1 rounded-full bg-slate-100 text-slate-600 font-semibold">
                          Read
                        </span>
                      <% } %>
                    </div>

                    <p class="text-sm text-slate-500">
                      <i class="fas fa-clock mr-1"></i>
                      <%= new Date(alert.createdAt).toLocaleString() %>
                    </p>
                  </div>
                </div>

                <% if (!alert.isRead) { %>
                  <form action="/smart-alerts/read/<%= alert._id %>" method="POST">
                    <button type="submit" class="px-4 py-2 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-700 transition">
                      Mark Read
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-16">
          <div class="w-20 h-20 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-4">
            <i class="fas fa-bell-slash text-3xl text-green-600"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-700 mb-2">No alerts yet</h3>
          <p class="text-slate-500 mb-6">
            Your alert section is clean right now. Keep tracking responsibly.
          </p>
          <a href="/track-screen-time" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition">
            Add Screen Time
          </a>
        </div>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    socket.on("screenTimeUpdated", function () {
      window.location.reload();
    });
  </script>
</body>
</html>